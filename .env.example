# Ejemplo de configuración para Lab 1
# Copia este archivo a .env y completa los valores reales

# Servidor
PORT=8080

# Seguridad JWT (Debe coincidir en todas las apps que se comuniquen)
JWT_SECRET=tu_secreto_super_seguro_de_al_menos_32_caracteres
JWT_EXPIRATION=86400000

# Base de Datos (Supabase)
DB_HOST=db.your-id.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=tu_password_de_supabase

# Firebase (Para historial de Chats)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CONFIG_PATH=/ruta/a/tu/archivo-serviceAccount.json
